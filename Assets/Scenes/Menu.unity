  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Fever: \nEssential for hydration, it helps regulate body temperature and
    prevent dehydration during fever.\n\nCold: \nKeeps the body hydrated and helps
    thin mucus for easier release.\n\nAllergy: \nFlushes out allergens and keeps
    the body hydrated.\n\nSore Throat:\nKeeps the throat moist and prevents further
    irritation.\n\nAcid Reflux: \nDilutes excess stomach acid and helps reduce irritation
    in the digestive tract."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
